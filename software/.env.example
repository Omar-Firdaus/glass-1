# Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Application type: Desktop app (or Web application with redirect URI below)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth redirect — must match Google Console authorized redirect URI
OAUTH_REDIRECT_URI=http://127.0.0.1:42813/callback

# OpenAI — GPT-4o vision for jaw-click scene analysis
OPENAI_API_KEY=sk-your-key-here
OPENAI_VISION_MODEL=gpt-4o

# Inworld — TTS for vision result announcements
# Use the Basic (Base64) authorization signature from Inworld Portal → API Keys
INWORLD_API_KEY=your-inworld-basic-api-key
# Or provide the key id + secret separately (plain text, not Base64):
# INWORLD_API_KEY=your-key-id
# INWORLD_API_KEY_SECRET=your-key-secret
INWORLD_TTS_MODEL=inworld-tts-2
INWORLD_TTS_VOICE=Freddie
